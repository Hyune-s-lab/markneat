<idea-plugin>
    <id>dev.hyunelab.markdownneat</id>
    <name>MarkdownNeat</name>
    <vendor url="https://github.com/Hyune-s-lab">Hyune-s-lab</vendor>

    <description><![CDATA[
        <p>A lightweight, read-only Markdown viewer for JetBrains IDEs.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.hyunelab.markdownneat.editor.MarkdownNeatFileEditorProvider"/>
        <applicationService serviceImplementation="dev.hyunelab.markdownneat.settings.MarkdownNeatSettings"/>
        <applicationConfigurable
                parentId="tools"
                id="dev.hyunelab.markdownneat.settings"
                displayName="MarkdownNeat"
                instance="dev.hyunelab.markdownneat.settings.MarkdownNeatSettingsConfigurable"/>
    </extensions>
</idea-plugin>
